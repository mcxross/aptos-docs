---
import Default from "@astrojs/starlight/components/PageTitle.astro";
import Breadcrumbs from "~/components/Breadcrumbs.astro";
import CopyPageButton from "~/components/CopyPageButton.astro";

const currentPath = Astro.url.pathname;
const t = Astro.props.t || Astro.locals.t;
const pageUrl = Astro.url.href;
---

<Breadcrumbs
  currentPath={currentPath}
  truncated
  useHomeIcon
  dynamicPrefixes={["move-reference", "rest-api"]}
  disableIntermediatePaths={["rest-api"]}
/>
<div class="page-title-row">
  <Default {...Astro.props}><slot /></Default>
  <CopyPageButton
    pageUrl={pageUrl}
    labels={{
      button: t("copyPage.button"),
      copied: t("copyPage.copied"),
      copyMarkdown: t("copyPage.copyMarkdown"),
      copyMarkdownDesc: t("copyPage.copyMarkdownDesc"),
      copyPlainText: t("copyPage.copyPlainText"),
      copyPlainTextDesc: t("copyPage.copyPlainTextDesc"),
      copyUrl: t("copyPage.copyUrl"),
      copyUrlDesc: t("copyPage.copyUrlDesc"),
      openInChatGPT: t("copyPage.openInChatGPT"),
      openInClaude: t("copyPage.openInClaude"),
      openInGemini: t("copyPage.openInGemini"),
      openInPerplexity: t("copyPage.openInPerplexity"),
      aiSection: t("copyPage.aiSection"),
      copySection: t("copyPage.copySection"),
    }}
  />
</div>

<style>
  .page-title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .page-title-row :global(h1) {
    flex: 1;
    min-width: 0;
  }

  .page-title-row :global(copy-page-dropdown) {
    flex-shrink: 0;
    margin-top: 1.25rem;
  }
</style>
